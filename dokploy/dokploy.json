{
  "name": "album-splitter",
  "description": "Split single-file MP3 albums into separate tracks. Downloads from YouTube supported.",
  "icon": "https://raw.githubusercontent.com/tolakang/album-splitter/master/.github/readme/hero.png",
  "services": [
    {
      "name": "album-splitter",
      "type": "docker",
      "image": "python:3.12-slim",
      "ports": [],
      "volumes": [
        {
          "source": "input",
          "destination": "/app/input"
        },
        {
          "source": "output",
          "destination": "/app/output"
        }
      ],
      "environment": [
        {
          "key": "PYTHONUNBUFFERED",
          "value": "1"
        }
      ],
      "commands": [
        "apt-get update && apt-get install -y ffmpeg git",
        "cd /app && pip install --no-cache-dir -e ."
      ]
    }
  ]
}
