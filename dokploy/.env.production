# Production Environment Variables for Album Splitter

# Flask secret key (CHANGE THIS!)
SECRET_KEY=change-this-to-a-unique-random-string

# Upload folder for audio files
UPLOAD_FOLDER=/app/uploads

# Output folder for split tracks
OUTPUT_FOLDER=/app/output

# Server port
PORT=8000

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Python output buffering (1=disabled, 0=enabled)
PYTHONUNBUFFERED=1

# Bytecode writing (1=disabled, 0=enabled)
PYTHONDONTWRITEBYTECODE=1
