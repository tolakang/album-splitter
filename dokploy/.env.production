# Production Environment Variables for Album Splitter

# Output folder for split tracks
OUTPUT_FOLDER=/app/output

# Temporary folder for processing
TEMP_FOLDER=/app/input

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Python output buffering (1=disabled, 0=enabled)
PYTHONUNBUFFERED=1

# Bytecode writing (1=disabled, 0=enabled)
PYTHONDONTWRITEBYTECODE=1
