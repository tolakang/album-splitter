# Album Splitter Environment Configuration

# Flask secret key (CHANGE THIS IN PRODUCTION!)
SECRET_KEY=your-secret-key-here

# Upload folder for audio files (inside container)
UPLOAD_FOLDER=/app/uploads

# Output folder for split tracks (inside container)
OUTPUT_FOLDER=/app/output

# Server port
PORT=8000

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Python output buffering (1=disabled, 0=enabled)
PYTHONUNBUFFERED=1

# Bytecode writing (1=disabled, 0=enabled)
PYTHONDONTWRITEBYTECODE=1
