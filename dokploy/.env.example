# Database
POSTGRES_DB=album_splitter
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme

# ========================================
# Application Domains (Traefik routing)
# ========================================
# Domain names for frontend & backend (NO protocol, NO https://, just the hostname)
FRONTEND_DOMAIN=<YOUR_DOMAIN>
BACKEND_DOMAIN=api.<YOUR_DOMAIN>

# Optional: sanitized domain overrides (leave blank to use above)
# Use these if FRONTEND_DOMAIN/BACKEND_DOMAIN contain a scheme by mistake
FRONTEND_HOST=
BACKEND_HOST=

# ========================================
# Application Ports (container ports)
# ========================================
FRONTEND_PORT=3000
BACKEND_PORT=3001

# ========================================
# Backend Configuration
# ========================================
NODE_ENV=production

# FRONTEND_URL: Public URL of frontend (used by backend for CORS)
# Must include protocol and be the FULL public URL your users will visit
# Example: https://album.example.com
FRONTEND_URL=https://<YOUR_DOMAIN>

# BACKEND_URL: Internal backend URL for frontend to connect to
BACKEND_URL=http://backend:3001

# ========================================
# Frontend Configuration
# ========================================
# API URL for frontend to backend (relative path for deployment)
NEXT_PUBLIC_API_URL=/api
