# Album Splitter Environment Variables
# Copy this file to .env and fill in the values

# Output folder for split tracks
OUTPUT_FOLDER=./output

# Optional: FFmpeg binary path (defaults to system ffmpeg)
FFMPEG_PATH=ffmpeg

# Optional: Temporary folder for downloads and processing
TEMP_FOLDER=./temp

# Optional: Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
